// Prisma schema — see https://pris.ly/d/prisma-schema
// Prisma 7 moves connection URLs to prisma.config.ts.
// Neon serverless adapter is wired in src/lib/db.ts via driverAdapters.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // driverAdapters is GA in Prisma 7 but Plan 01-01 spec + Plan 01-03 acceptance-criteria
  // grep for this literal, so keep the declaration even though it emits a deprecation warning.
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth (auth-global, NOT RLS-enabled) ────────────────────────────

model User {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  clinic        Clinic?
}

model Session {
  id        String   @id
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId            String
  accountId             String
  password              String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─── Tenant-scoped (RLS-enabled via 001-rls-policies.sql) ──────────────────

enum AccentColor {
  sage
  terracotta
  midnight
  wine
  forest
  clay
}

enum PlanStatus {
  draft
  published
  archived
}

// Phase 2 — Stripe Connect onboarding lifecycle.
// The five states are derived centrally via deriveOnboardingState() in
// src/lib/stripe/types.ts. Do NOT hand-compute them elsewhere — the derivation
// is the single source of truth so dashboard UI + webhook persistence stay in
// sync.
enum OnboardingState {
  not_started // no stripeAccountId yet
  in_progress // account created, owner in Stripe-hosted flow
  action_required // returned from Stripe but requirements.currently_due not empty
  complete // charges_enabled && payouts_enabled && !disabled_reason
  restricted // disabled_reason is set (capability revoked by Stripe)
}

model Clinic {
  id           String      @id @default(uuid()) @db.Uuid
  ownerUserId  String      @unique
  owner        User        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  practiceName String
  slug         String      @unique
  logoUrl      String?
  accentColor  AccentColor @default(sage)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  plans        Plan[]
  members      Member[]

  // ─── Stripe Connect (Phase 2 PUB-01/PUB-02) ──────────────────────────────
  // These fields are written ONLY by the webhook handler (Plan 02-03) and by
  // the onboarding server action when persisting the baseline snapshot after
  // account creation. UI routes must never mutate them — they mirror
  // authoritative state owned by Stripe.
  stripeAccountId        String?         @unique // acct_… from stripe.accounts.create
  stripeChargesEnabled   Boolean         @default(false) // mirrored from account.updated
  stripePayoutsEnabled   Boolean         @default(false) // mirrored from account.updated
  stripeDetailsSubmitted Boolean         @default(false) // mirrored from account.updated
  stripeDisabledReason   String? // requirements.disabled_reason
  stripeRequirements     Json? // full requirements object snapshot
  stripeOnboardingState  OnboardingState @default(not_started)
  stripeCapabilitiesAt   DateTime? // last time we updated from a webhook

  @@index([slug])
}

model Plan {
  id                        String     @id @default(uuid()) @db.Uuid
  clinicId                  String     @db.Uuid
  clinic                    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  status                    PlanStatus @default(draft)
  builderInputs             Json
  monthlyProgramOverheadUsd Decimal    @default(500) @db.Decimal(10, 2)
  tierCount                 Int
  publishedAt               DateTime?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  tiers                     PlanTier[]

  @@index([clinicId, status])
  @@index([clinicId, status, publishedAt])
}

model PlanTier {
  id                            String   @id @default(uuid()) @db.Uuid
  planId                        String   @db.Uuid
  plan                          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  clinicId                      String   @db.Uuid
  tierKey                       String
  tierName                      String
  includedServices              Json
  retailValueBundledCents       Int
  monthlyFeeCents               Int
  stripeFeePerChargeCents       Int
  platformFeePerChargeCents     Int
  clinicGrossPerPetPerYearCents Int
  breakEvenMembers              Int
  ordering                      Int
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  // ─── Phase 3 Publish (PUB-03, BLDR-08) ───────────────────────────────────
  // Nullable to preserve existing draft rows. Written ONLY by the publishPlan
  // server action (plan 03-02) and updatePlanPrices (plan 03-04). Never
  // written by UI code directly. Invariants:
  //   - stripeProductId is set at first publish and never rotates (BLDR-08).
  //   - stripePriceId is the ACTIVE price; rotates on price edit.
  //   - stripePriceHistory is append-only: [{ priceId, unitAmountCents, createdAt, replacedAt }].
  //     The current price also has a row with replacedAt = null.
  //   - publishedAt is the first-publish timestamp; subsequent edits do not reset it.
  stripeProductId    String?
  stripePriceId      String?
  stripePriceHistory Json?
  publishedAt        DateTime?

  members Member[]

  @@index([planId, ordering])
  @@index([clinicId])
  @@index([stripePriceId])
  @@index([planId, publishedAt])
}

// ─── Stripe webhook idempotency store (Phase 2 PUB-02) ─────────────────────
// Written by the webhook handler BEFORE any clinic context is resolved, so
// the PK is `event.id` (Stripe's globally-unique event ID). NOT tenant-scoped
// via a clinicId FK — a connectedAccount event may arrive before the Clinic
// is fully linked, and the event log must survive clinic deletions for audit.
// RLS is enabled in prisma/sql/002-stripe-rls.sql with the same two-mode
// pattern as Clinic (permissive when GUC unset, strict when set).
model StripeEvent {
  id                 String    @id // Stripe event.id, e.g. evt_1AbCdEf…
  type               String // e.g. account.updated
  connectedAccountId String? // event.account — null for platform events
  apiVersion         String? // event.api_version
  payload            Json // full event object for forensic replay
  receivedAt         DateTime  @default(now())
  processedAt        DateTime? // null = in-flight or failed
  processingError    String? // last error message if processing failed

  @@index([connectedAccountId])
  @@index([type, receivedAt])
  @@index([processedAt])
}

// ─── Phase 4 — Subscription member state (PAY-01..07, DASH-03, DASH-05) ─────
//
// A Member row is created from `checkout.session.completed` (see plan 04-03).
// Written ONLY by the webhook dispatcher and the cancelMember server action.
// UI + dashboard loaders must read via withClinic() so RLS enforces isolation.
//
// Invariants:
//   - `status` is the ENUM MemberStatus — NEVER a boolean (PAY-07).
//   - (clinicId, stripeSubscriptionId) is unique → webhook replay never
//     creates a duplicate member even if dispatch raced (PITFALLS.md #2).
//   - `canceledAt` is set optimistically when the owner clicks Cancel, and
//     confirmed by the customer.subscription.deleted webhook. `status` only
//     flips to `canceled` on the webhook; never on the UI click.
//   - `currentPeriodEnd` mirrors Stripe's current_period_end so the dashboard
//     can render cancellation countdown without a Stripe round-trip.
//
// Smart Retries are OFF per locked decision — payment_failed_at records the
// single failure that flipped the member to past_due. No retry schedule.
enum MemberStatus {
  active
  past_due
  canceled
}

model Member {
  id         String   @id @default(uuid()) @db.Uuid
  clinicId   String   @db.Uuid
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  planTierId String   @db.Uuid
  planTier   PlanTier @relation(fields: [planTierId], references: [id], onDelete: Restrict)

  // Stripe linkage — mirrored from webhook events, never authored by UI.
  stripeCustomerId     String // cus_…
  stripeSubscriptionId String @unique // sub_… — unique across platform

  // Custom fields collected inside Stripe Checkout (BLDR-07).
  petName    String
  species    String // "dog" | "cat" (Checkout custom-field dropdown)
  ownerEmail String // seeded from Checkout customer_email

  // Lifecycle.
  status           MemberStatus @default(active)
  currentPeriodEnd DateTime? // mirrored from subscription.current_period_end
  enrolledAt       DateTime     @default(now()) // first invoice.paid timestamp
  paymentFailedAt  DateTime? // set by invoice.payment_failed (PAY-05, DASH-03)
  canceledAt       DateTime? // set optimistically by owner click + confirmed by webhook (DASH-05)

  // Phase 5 NOTIF — idempotency stamps for the two async jobs. The worker
  // treats a non-null value as "already sent, skip." This guards against
  // pg-boss retry-after-success edge cases + operator manual re-enqueues.
  welcomePacketSentAt DateTime? // set by send-welcome-packet handler on 2xx
  ownerNotifiedAt     DateTime? // set by notify-owner-new-enrollment handler on 2xx

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes optimized for the dashboard members page + webhook upsert.
  @@unique([clinicId, stripeSubscriptionId]) // webhook replay safety
  @@index([clinicId, status]) // filter past_due / active
  @@index([clinicId, paymentFailedAt]) // DASH-03 filterable failed flag
  @@index([planTierId])
}
