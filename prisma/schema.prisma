// Prisma schema — see https://pris.ly/d/prisma-schema
// Prisma 7 moves connection URLs to prisma.config.ts.
// Neon serverless adapter is wired in src/lib/db.ts via driverAdapters.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // driverAdapters is GA in Prisma 7 but Plan 01-01 spec + Plan 01-03 acceptance-criteria
  // grep for this literal, so keep the declaration even though it emits a deprecation warning.
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth (auth-global, NOT RLS-enabled) ────────────────────────────

model User {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  clinic        Clinic?
}

model Session {
  id        String   @id
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId            String
  accountId             String
  password              String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─── Tenant-scoped (RLS-enabled via 001-rls-policies.sql) ──────────────────

enum AccentColor {
  sage
  terracotta
  midnight
  wine
  forest
  clay
}

enum PlanStatus {
  draft
  published
  archived
}

// Phase 2 — Stripe Connect onboarding lifecycle.
// The five states are derived centrally via deriveOnboardingState() in
// src/lib/stripe/types.ts. Do NOT hand-compute them elsewhere — the derivation
// is the single source of truth so dashboard UI + webhook persistence stay in
// sync.
enum OnboardingState {
  not_started // no stripeAccountId yet
  in_progress // account created, owner in Stripe-hosted flow
  action_required // returned from Stripe but requirements.currently_due not empty
  complete // charges_enabled && payouts_enabled && !disabled_reason
  restricted // disabled_reason is set (capability revoked by Stripe)
}

model Clinic {
  id           String      @id @default(uuid()) @db.Uuid
  ownerUserId  String      @unique
  owner        User        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  practiceName String
  slug         String      @unique
  logoUrl      String?
  accentColor  AccentColor @default(sage)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  plans        Plan[]

  // ─── Stripe Connect (Phase 2 PUB-01/PUB-02) ──────────────────────────────
  // These fields are written ONLY by the webhook handler (Plan 02-03) and by
  // the onboarding server action when persisting the baseline snapshot after
  // account creation. UI routes must never mutate them — they mirror
  // authoritative state owned by Stripe.
  stripeAccountId        String?         @unique // acct_… from stripe.accounts.create
  stripeChargesEnabled   Boolean         @default(false) // mirrored from account.updated
  stripePayoutsEnabled   Boolean         @default(false) // mirrored from account.updated
  stripeDetailsSubmitted Boolean         @default(false) // mirrored from account.updated
  stripeDisabledReason   String? // requirements.disabled_reason
  stripeRequirements     Json? // full requirements object snapshot
  stripeOnboardingState  OnboardingState @default(not_started)
  stripeCapabilitiesAt   DateTime? // last time we updated from a webhook

  @@index([slug])
}

model Plan {
  id                        String     @id @default(uuid()) @db.Uuid
  clinicId                  String     @db.Uuid
  clinic                    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  status                    PlanStatus @default(draft)
  builderInputs             Json
  monthlyProgramOverheadUsd Decimal    @default(500) @db.Decimal(10, 2)
  tierCount                 Int
  publishedAt               DateTime?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  tiers                     PlanTier[]

  @@index([clinicId, status])
}

model PlanTier {
  id                            String   @id @default(uuid()) @db.Uuid
  planId                        String   @db.Uuid
  plan                          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  clinicId                      String   @db.Uuid
  tierKey                       String
  tierName                      String
  includedServices              Json
  retailValueBundledCents       Int
  monthlyFeeCents               Int
  stripeFeePerChargeCents       Int
  platformFeePerChargeCents     Int
  clinicGrossPerPetPerYearCents Int
  breakEvenMembers              Int
  ordering                      Int
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([planId, ordering])
  @@index([clinicId])
}

// ─── Stripe webhook idempotency store (Phase 2 PUB-02) ─────────────────────
// Written by the webhook handler BEFORE any clinic context is resolved, so
// the PK is `event.id` (Stripe's globally-unique event ID). NOT tenant-scoped
// via a clinicId FK — a connectedAccount event may arrive before the Clinic
// is fully linked, and the event log must survive clinic deletions for audit.
// RLS is enabled in prisma/sql/002-stripe-rls.sql with the same two-mode
// pattern as Clinic (permissive when GUC unset, strict when set).
model StripeEvent {
  id                 String    @id // Stripe event.id, e.g. evt_1AbCdEf…
  type               String // e.g. account.updated
  connectedAccountId String? // event.account — null for platform events
  apiVersion         String? // event.api_version
  payload            Json // full event object for forensic replay
  receivedAt         DateTime  @default(now())
  processedAt        DateTime? // null = in-flight or failed
  processingError    String? // last error message if processing failed

  @@index([connectedAccountId])
  @@index([type, receivedAt])
  @@index([processedAt])
}
